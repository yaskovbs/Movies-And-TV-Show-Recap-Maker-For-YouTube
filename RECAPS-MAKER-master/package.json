{
  "name": "recaps-maker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy-ffmpeg": "node -e \"const fs=require('fs');const src='node_modules/@ffmpeg/core/dist';const dst='public';['ffmpeg-core.js','ffmpeg-core.wasm','ffmpeg-core.worker.js'].forEach(f=>{fs.copyFileSync(src+'/'+f,dst+'/'+f);console.log('Copied',f)})\"",
    "postinstall": "npm run copy-ffmpeg"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.11.0",
    "@ffmpeg/ffmpeg": "^0.11.0",
    "@supabase/supabase-js": "^2.57.4",
    "firebase": "^12.10.0",
    "framer-motion": "^12.23.13",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-google-recaptcha": "^3.1.0",
    "react-router-dom": "^7.9.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "postcss": "^8.4.35",
    "supabase": "^2.76.16",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5"
  }
}
